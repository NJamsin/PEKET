timeshift=Uniform(minimum=-8.0, maximum=0., name='trigger_time', latex_label='$t_0$', unit=None, boundary=None)
KNphi=Uniform(minimum=15.0, maximum=75.0, name='KNphi', latex_label='$\\Phi$', unit=None, boundary=None)
inclination_EM=Uniform(minimum=0.0, maximum=1.5707963267948966, name='inclination_EM', latex_label='$\\iota$', unit=None, boundary=None)
log10_mej_dyn=Uniform(minimum=-3.0, maximum=-1.69, name='log10_mej_dyn', latex_label='$\\log_{10}M^{\\rm{dyn}}_{\\rm{ej}}$', unit=None, boundary=None)
log10_mej_wind=Uniform(minimum=-2.0, maximum=-0.89, name='log10_mej_wind', latex_label='$\\log_{10}M^{\\rm{wind}}_{\\rm{ej}}$', unit=None, boundary=None)
em_syserr=Uniform(minimum=0.3, maximum=3, name='em_syserr', latex_label='$\\sigma^{\\rm{err}}_{\\rm{ej}}$', unit=None, boundary=None)
luminosity_distance=Uniform(minimum=10, maximum=200, name='luminosity_distance', latex_label='$D_L$', unit=None, boundary=None)